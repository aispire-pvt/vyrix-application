# Copy this to .env and fill in values before running docker-compose up

# Required — server won't start without these
JWT_SECRET=change_me_min_32_chars_random_string_here
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend build args
VITE_API_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# CORS — where the frontend is served from
CLIENT_URL=http://localhost:80

# Email (Brevo) — optional in dev, required in production
BREVO_API_KEY=
BREVO_SENDER=
FEEDBACK_EMAIL=

# ImageKit — required for profile picture uploads
IMAGEKIT_PRIVATE_KEY=

# Supabase — required for catalog sync
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
