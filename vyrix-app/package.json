{
  "name": "vyrix-app",
  "version": "0.1.7",
  "description": "Vyrix — structured research workspace for design students",
  "main": "electron/main.js",
  "type": "commonjs",
  "author": {
    "name": "Aispire Private Limited",
    "email": "business@aispire.co.in"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "@supabase/supabase-js": "^2.45.0",
    "@tiptap/extension-character-count": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-typography": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "axios": "^1.7.7",
    "better-sqlite3": "^11.5.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.26.2",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^29.4.6",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13"
  },
  "build": {
    "appId": "in.vyrix.app",
    "productName": "Vyrix",
    "copyright": "Copyright © 2025 Aispire Private Limited",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "artifactName": "${productName}-${version}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vyrix"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Vyrix ${version}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Office"
    },
    "publish": {
      "provider": "github",
      "owner": "aispire-pvt",
      "repo": "vyrix-application",
      "releaseType": "draft"
    }
  }
}
