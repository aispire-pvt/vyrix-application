# MongoDB connection string (MongoDB Atlas)
MONGO_URI=

# Secret used to sign JWTs (use a long random string)
JWT_SECRET=

# ImageKit private key (for profile picture uploads)
IMAGEKIT_PRIVATE_KEY=

# Frontend origin allowed by CORS (your Vercel URL in production)
CLIENT_URL=http://localhost:5173

# OTP email — local dev uses Gmail SMTP (App Password)
EMAIL_USER=
EMAIL_PASS=

# OTP email — production (Render blocks SMTP, so use Brevo's HTTP API)
# When BREVO_API_KEY is set, email is sent via Brevo instead of SMTP.
BREVO_API_KEY=
BREVO_SENDER=VanshSrivastava709@gmail.com

# Set to "production" when deployed so the auth cookie uses SameSite=None; Secure
NODE_ENV=development
