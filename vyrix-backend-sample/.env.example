# MongoDB connection string (MongoDB Atlas)
MONGO_URI=

# Secret used to sign JWTs (use a long random string)
JWT_SECRET=

# ImageKit private key (for profile picture uploads)
IMAGEKIT_PRIVATE_KEY=

# Frontend origin allowed by CORS (your Vercel URL in production)
CLIENT_URL=http://localhost:5173

# OTP email — sent via the Brevo HTTP API (SMTP is blocked on most hosts).
# If BREVO_API_KEY is unset (e.g. local dev), the OTP is logged to the console instead.
# BREVO_SENDER must be a verified sender (or authenticated domain) in your Brevo account.
BREVO_API_KEY=
BREVO_SENDER=vanshsrivastava709@gmail.com

# Google OAuth — Web client ID from Google Cloud Console (public value).
# Used to verify that Google access tokens were issued for this app.
GOOGLE_CLIENT_ID=

# Where user suggestions / bug reports are emailed (defaults to BREVO_SENDER).
FEEDBACK_EMAIL=

# Set to "production" when deployed so the auth cookie uses SameSite=None; Secure
NODE_ENV=development
